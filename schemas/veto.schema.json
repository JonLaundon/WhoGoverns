{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "veto.schema.json",
  "title": "Veto",
  "$comment": "A genuine statutory BLOCK (Annex A6.5). Active from Spiral 2. A veto is a DERIVED projection of the underlying power (decision 2026-07-14): derived_from_record_id (the canonical Power) and decision_affected (what is blocked) are BOTH required — a veto is never a free-standing primitive. modality is const 'veto'. STRICT test: only a real block; 'must be consulted' is a Duty, soft influence is not recorded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "veto_id",
    "holder_type",
    "body_id",
    "veto_label",
    "veto_type",
    "modality",
    "strength",
    "summary",
    "source_id",
    "provision_key",
    "citation",
    "derived_from_record_id",
    "decision_affected",
    "record_status"
  ],
  "properties": {
    "veto_id": {
      "type": "string",
      "pattern": "^veto-[a-z0-9-]+$"
    },
    "holder_type": {
      "type": "string",
      "enum": [
        "office",
        "body"
      ]
    },
    "office_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "body_id": {
      "type": "string",
      "pattern": "^uk-state-body-[a-z0-9-]+$"
    },
    "veto_label": {
      "type": "string"
    },
    "veto_type": {
      "type": "string",
      "enum": [
        "consent_required",
        "concurrence_required",
        "approval_required",
        "objection_power",
        "call_in_power",
        "licence_refusal",
        "designation_power",
        "environmental_assessment",
        "other"
      ]
    },
    "modality": {
      "const": "veto"
    },
    "strength": {
      "type": "string",
      "enum": [
        "hard_stop",
        "strong_delay",
        "procedural_risk",
        "advisory_only"
      ]
    },
    "summary": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "provision_key": {
      "type": "string"
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provision",
        "url"
      ],
      "properties": {
        "provision": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "quote": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "derived_from_record_id": {
      "type": "string",
      "pattern": "^power-[a-z0-9-]+$"
    },
    "decision_affected": {
      "type": "string"
    },
    "blocks_holder_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "office",
        "body",
        null
      ]
    },
    "blocks_office_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocks_body_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocks_provision_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "trigger": {
      "type": [
        "string",
        "null"
      ]
    },
    "overridable": {
      "type": "string",
      "enum": [
        "yes",
        "no",
        "unknown"
      ]
    },
    "override_mechanism": {
      "type": [
        "string",
        "null"
      ]
    },
    "failure_consequence": {
      "type": "string",
      "enum": [
        "invalid_decision",
        "judicial_review_risk",
        "delay",
        "sanction",
        "unknown"
      ]
    },
    "in_force_from": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "in_force_to": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "legal_status": {
      "type": "string",
      "enum": [
        "current",
        "repealed",
        "prospective",
        "historical",
        "unknown"
      ]
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extracted_by": {
          "type": "string",
          "enum": [
            "llm",
            "human"
          ]
        },
        "extraction_run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "requires_review": {
          "type": "boolean"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verification_status": {
          "type": "string",
          "enum": [
            "unverified",
            "machine_verified",
            "single_checked",
            "double_checked",
            "rejected"
          ]
        },
        "verified_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "verified_date": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "verification_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_status": {
      "type": "string",
      "enum": [
        "draft",
        "extracted",
        "verified",
        "published",
        "deprecated"
      ]
    },
    "blocks_record_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "power",
        "duty",
        null
      ],
      "description": "Whether the obstructed record is a Power or a Duty."
    },
    "blocks_record_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "The specific operative record this veto obstructs, where it is modelled. GENERALISED from the earlier `blocks_power_id` (2026-07-20) after the WIA s.16 breadcrumb trawl showed a veto can block the discharge of a DUTY, not only the exercise of a power: WIA 1991 s.16 says the Authority 'SHALL ... make such modifications', and s.16A lets the CMA direct it not to. Populated uniformly regardless of statutory shape — in an embedded-consent provision it equals derived_from_record_id; in a free-standing block it points at the obstructed record elsewhere. Null has two meanings, distinguishable via blocks_body_id: the blocked party is outside the modelled state, or the blocked party is modelled but its record is not yet extracted (a coverage gap validate.py warns on). Contrast derived_from_record_id, which is PROVENANCE, not the target."
    }
  }
}

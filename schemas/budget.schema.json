{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "budget.schema.json",
  "title": "Budget",
  "type": "object",
  "additionalProperties": false,
  "required": ["budget_record_id", "body_id", "financial_year", "budget_type", "amount", "currency"],
  "properties": {
    "budget_record_id": { "type": "string" },
    "body_id": { "type": "string" },
    "financial_year": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "budget_type": { "type": "string", "enum": ["resource_del", "capital_del", "resource_ame", "capital_ame", "ame", "income", "expenditure", "grant_in_aid", "total_managed_expenditure", "other"] },
    "basis": { "type": "string", "enum": ["net", "gross"] },
    "programme": { "type": ["string", "null"] },
    "amount": { "type": "number" },
    "currency": { "type": "string" },
    "cash_or_real_terms": { "type": "string", "enum": ["cash", "real"] },
    "source_id": { "type": ["string", "null"] },
    "citation": { "type": "object" },
    "notes": { "type": ["string", "null"] },
    "record_status": { "type": "string", "enum": ["draft", "extracted", "verified", "published", "deprecated"] }
  }
}
